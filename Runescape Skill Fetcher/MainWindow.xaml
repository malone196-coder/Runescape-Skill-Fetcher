<Window x:Class="Runescape_Skill_Fetcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Runescape_Skill_Fetcher"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBox x:Name="PlayerUsername" HorizontalAlignment="Left" Margin="351,19,0,0" TextWrapping="Wrap" Text="Enter your OSRS username" VerticalAlignment="Top" Width="151" SelectionOpacity="0.2" TextChanged="PlayerUsername_TextChanged" Height="20"/>
        <TextBlock HorizontalAlignment="Left" Margin="271,21,0,0" TextWrapping="Wrap" Text="Username:" VerticalAlignment="Top" RenderTransformOrigin="-0.147,0.681" Width="80"/>
        <Button x:Name="FetchStatsButton" Content="Fetch Stats" HorizontalAlignment="Left" Margin="507,19,0,0" VerticalAlignment="Top" Click="FetchStatsButton_Click"/>
        <RichTextBox x:Name="PlayerStatsDisplay" Margin="0,64,0,0" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" >
            <FlowDocument>
                <Paragraph>
                    <Run Text="Skills will populate here!"/>
                </Paragraph>
            </FlowDocument>
        </RichTextBox>

    </Grid>
</Window>
